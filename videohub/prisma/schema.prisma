generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  refreshToken String?
  bio          String?
  avatarUrl    String?  // path to uploaded avatar image
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos              Video[]
  likes               Like[]
  comments            Comment[]
  following           Follow[]       @relation("follower")
  followers           Follow[]       @relation("following")
  notifications       Notification[] @relation("recipient")
  sentNotifications   Notification[] @relation("actor")
  watchHistory        WatchHistory[]
  playlists           Playlist[]
}

model Video {
  id           String      @id @default(uuid())
  title        String
  description  String?
  filePath     String?     // original uploaded file path
  hlsUrl       String?     // path to master.m3u8 for adaptive streaming
  thumbnailUrl String?     // path to generated JPEG thumbnail
  userId       String
  likeCount    Int         @default(0)
  commentCount Int         @default(0)
  viewCount    Int         @default(0)
  status       VideoStatus @default(PROCESSING)
  duration     Int?        // seconds
  category     String?     // e.g. "Gaming", "Music", "Education"
  tags         String[]    // e.g. ["tutorial", "react", "typescript"]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]
  watchHistory WatchHistory[]
  playlists    PlaylistVideo[]
  chapters     VideoChapter[]

  @@index([title])
  @@index([userId])
  @@index([status])
  @@index([viewCount])  // fast "most viewed" queries
  @@index([category])   // fast "filter by category" queries
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}

model Like {
  userId  String
  videoId String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])  // composite key — one like per user per video
  @@index([videoId])       // fast "count likes for a video" queries
  @@index([userId])        // fast "videos liked by a user" queries
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])  // fast "get comments for a video" queries
  @@index([userId])   // fast "get comments by a user" queries
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // followerId = the user who clicked "follow"
  // followingId = the user being followed
  follower  User @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])  // composite key — can only follow once
  @@index([followerId])            // fast "who does this user follow"
  @@index([followingId])           // fast "who follows this user"
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           // who receives it
  actorId   String           // who triggered it
  type      NotificationType
  videoId   String?          // optional — not all notifications relate to a video
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User  @relation("recipient", fields: [userId],  references: [id], onDelete: Cascade)
  actor User  @relation("actor",     fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId])           // fast "get my notifications"
  @@index([userId, read])     // fast "get my unread notifications"
}

enum NotificationType {
  NEW_FOLLOWER
  VIDEO_LIKED
  VIDEO_COMMENTED
}

model WatchHistory {
  userId    String
  videoId   String
  watchedAt DateTime @default(now()) @updatedAt  // upsert updates this timestamp

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])   // one entry per user per video — upserted on re-watch
  @@index([userId])         // fast "get my history"
}

model Playlist {
  id          String   @id @default(uuid())
  title       String
  description String?
  userId      String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos PlaylistVideo[]

  @@index([userId])
}

model PlaylistVideo {
  playlistId String
  videoId    String
  position   Int      @default(0)  // ordering within the playlist
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video    Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([playlistId, videoId])
  @@index([playlistId])
}

model VideoChapter {
  id        String @id @default(uuid())
  videoId   String
  title     String
  startTime Int    // seconds from start
  position  Int    // display order

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}
