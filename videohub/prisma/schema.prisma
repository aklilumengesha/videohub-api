generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  refreshToken String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos    Video[]
  likes     Like[]
  comments  Comment[]
  following Follow[]  @relation("follower")   // users this user follows
  followers Follow[]  @relation("following")  // users following this user
}

model Video {
  id           String      @id @default(uuid())
  title        String
  description  String?
  filePath     String?
  userId       String
  likeCount    Int         @default(0)
  commentCount Int         @default(0)
  status       VideoStatus @default(PROCESSING)
  duration     Int?        // seconds
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]

  @@index([title])
  @@index([userId])
  @@index([status])
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}

model Like {
  userId  String
  videoId String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])  // composite key — one like per user per video
  @@index([videoId])       // fast "count likes for a video" queries
  @@index([userId])        // fast "videos liked by a user" queries
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])  // fast "get comments for a video" queries
  @@index([userId])   // fast "get comments by a user" queries
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  // followerId = the user who clicked "follow"
  // followingId = the user being followed
  follower  User @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])  // composite key — can only follow once
  @@index([followerId])            // fast "who does this user follow"
  @@index([followingId])           // fast "who follows this user"
}
